# NightPOS — raíz del dominio (nightpos.ribersoft.com)
# Arquitectura oficial Opción A: API limpia /api/v1 → backend/public/index.php
# LiteSpeed / Apache + mod_rewrite — NO borrar bloque PHP de cPanel

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # JWT / print agent device_key
    RewriteCond %{HTTP:Authorization} .
    RewriteRule ^ - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

    # Archivos y carpetas reales (assets, icons, backend/public/health.php, …)
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # API limpia → Laravel (URL oficial: /api/v1/...)
    RewriteRule ^api/ backend/public/index.php [L,QSA]

    # Storage público Laravel (symlink backend/public/storage)
    RewriteRule ^storage/(.*)$ backend/public/storage/$1 [L]

    # Acceso directo legacy /backend/public/... (transición; preferir /api/v1)
    RewriteRule ^backend/ - [L]

    # PWA off: no servir index.html como sw.js (evita MIME text/html)
    RewriteRule ^(sw\.js|registerSW\.js|workbox-[^/]+\.js|mockServiceWorker\.js)$ - [R=404,L]

    # SPA Vue — rutas de la app (refresh en /login, /nightpos/*, …)
    RewriteCond %{REQUEST_URI} !^/api/
    RewriteCond %{REQUEST_URI} !^/backend/
    RewriteCond %{REQUEST_URI} !^/storage/
    RewriteRule ^ index.html [L]
</IfModule>

<IfModule mod_headers.c>
    <FilesMatch "^(sw\.js|registerSW\.js|workbox-.*\.js|mockServiceWorker\.js)$">
        Header set Cache-Control "no-cache, no-store, must-revalidate"
    </FilesMatch>
</IfModule>

<FilesMatch "^\.">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</FilesMatch>
