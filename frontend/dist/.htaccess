# NightPOS — raíz del dominio (nightpos.ribersoft.com)
# Vue SPA + Laravel API — versión MÍNIMA para cPanel/LiteSpeed
# NO eliminar el bloque php de cPanel al final de este archivo en el servidor.

DirectoryIndex index.html

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # Authorization → PHP/Laravel (agente impresión, JWT Bearer)
    RewriteCond %{HTTP:Authorization} .
    RewriteRule ^ - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

    # Archivos reales (assets/, icons/, manifest, backend/public/health.php, …)
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # API limpia: /api/v1/* → Laravel front controller
    RewriteRule ^api/ backend/public/index.php [L,QSA]

    # Storage público Laravel (/storage/ → symlink backend/public/storage)
    RewriteRule ^storage/(.*)$ backend/public/storage/$1 [L]

    # PWA off: 404 explícito — evita servir index.html como sw.js (MIME text/html)
    RewriteRule ^(sw\.js|registerSW\.js|mockServiceWorker\.js|workbox-[^/]+\.js)$ - [R=404,L]

    # Vue Router history: /login, /nightpos/* — excluir API, legacy backend y storage
    RewriteCond %{REQUEST_URI} !^/api/
    RewriteCond %{REQUEST_URI} !^/backend/
    RewriteCond %{REQUEST_URI} !^/storage/
    RewriteRule ^ index.html [L]
</IfModule>

# php -- BEGIN cPanel-generated handler, do not edit
# cPanel inyecta AddHandler aquí. En el servidor: pegar reglas rewrite ARRIBA
# y dejar intacto el bloque que ya exista abajo. Ejemplo típico PHP 8.2:
# <IfModule mime_module>
#   AddHandler application/x-httpd-ea-php82 .php .php8 .phtml
# </IfModule>
# php -- END cPanel-generated handler, do not edit
