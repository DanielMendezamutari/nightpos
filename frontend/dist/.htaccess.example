# NightPOS — SPA en raíz + Laravel en /backend/public/
# Copiar a la raíz del dominio (junto a index.html) como .htaccess
# Ajustar según hosting (LiteSpeed suele ser compatible con mod_rewrite)

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Archivos y carpetas reales (assets, backend/, health.php en raíz si existe)
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Laravel — no reescribir a index.html del frontend
    RewriteRule ^backend/ - [L]

    # API legacy en /api/v1 (si existe proxy o symlink; si no, omitir bloque)
    RewriteRule ^api/ backend/public/index.php [L,QSA]

    # SPA — solo rutas Vue; nunca API ni backend
    RewriteCond %{REQUEST_URI} !^/backend/
    RewriteCond %{REQUEST_URI} !^/api/
    RewriteRule ^ index.html [L]
</IfModule>

# Service worker: no cachear agresivamente (evita SW viejo tras deploy)
<IfModule mod_headers.c>
    <FilesMatch "^(sw\.js|registerSW\.js|workbox-.*\.js)$">
        Header set Cache-Control "no-cache, no-store, must-revalidate"
    </FilesMatch>
</IfModule>
