# NightPOS — raíz del dominio — Arquitectura oficial Opción A
# Copiar como frontend/public/.htaccess (se incluye en dist/ al build)

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    RewriteCond %{HTTP:Authorization} .
    RewriteRule ^ - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    RewriteRule ^api/ backend/public/index.php [L,QSA]
    RewriteRule ^storage/(.*)$ backend/public/storage/$1 [L]
    RewriteRule ^backend/ - [L]

    RewriteRule ^(sw\.js|registerSW\.js|workbox-[^/]+\.js|mockServiceWorker\.js)$ - [R=404,L]

    RewriteCond %{REQUEST_URI} !^/api/
    RewriteCond %{REQUEST_URI} !^/backend/
    RewriteCond %{REQUEST_URI} !^/storage/
    RewriteRule ^ index.html [L]
</IfModule>
