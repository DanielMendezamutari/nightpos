# NightPOS — raíz del dominio (nightpos.ribersoft.com)
# SPA Vue en / + Laravel en /backend/public/
# LiteSpeed / Apache + mod_rewrite

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # Authorization header (JWT / Bearer en algunos hostings)
    RewriteCond %{HTTP:Authorization} .
    RewriteRule ^ - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

    # Archivos y carpetas reales (assets, icons, manifest, backend/public/health.php, etc.)
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Laravel — no enviar al index.html del frontend
    RewriteRule ^backend/ - [L]

    # Alias corto opcional: /api/v1/... → Laravel (misma app que /backend/public/api/v1)
    RewriteRule ^api/(.*)$ backend/public/index.php [L,QSA]

    # SPA Vue — solo rutas de la app
    RewriteCond %{REQUEST_URI} !^/backend/
    RewriteCond %{REQUEST_URI} !^/api/
    RewriteRule ^ index.html [L]
</IfModule>

# PWA desactivada: si quedan archivos viejos, no cachearlos agresivamente
<IfModule mod_headers.c>
    <FilesMatch "^(sw\.js|registerSW\.js|workbox-.*\.js|mockServiceWorker\.js)$">
        Header set Cache-Control "no-cache, no-store, must-revalidate"
    </FilesMatch>
</IfModule>

# No servir dotfiles (.env, .git, etc.) si llegaran a la raíz por error
<FilesMatch "^\.">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</FilesMatch>
