# Build de producción (pnpm run build)
# El frontend y la API comparten dominio (nightpos.ribersoft.com),
# por eso la URL es RELATIVA: el navegador resuelve contra el mismo origin.
# API real: https://nightpos.ribersoft.com/backend/public/api/v1
VITE_API_BASE_URL=/backend/public/api/v1

# Sin mocks en producción
VITE_USE_MSW=false
