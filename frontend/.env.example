# URL base de la API Laravel (prefijo real: /api/v1)
# En dev con pnpm run dev: usar /api/v1 y el proxy de Vite hacia nightpos.test
# En build de producción se usa .env.production (ruta /backend/public/api/v1)
VITE_API_BASE_URL=/api/v1

# Destino del proxy Vite (backend XAMPP / vhost) — solo dev
VITE_BACKEND_URL=http://nightpos.test

# MSW mock de la plantilla (false = API real)
VITE_USE_MSW=false
