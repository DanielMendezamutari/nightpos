# URL base de la API Laravel (prefijo real: /api/v1)
# Dev (pnpm run dev): /api/v1 + proxy Vite → nightpos.test
# Producción estabilización: /backend/public/api/v1 (ver .env.production)
# Producción futura (Opción A): /api/v1 cuando rewrite raíz validado
VITE_API_BASE_URL=/api/v1

# Destino del proxy Vite (backend XAMPP / vhost) — solo dev
VITE_BACKEND_URL=http://nightpos.test

# Timeout axios en ms (hosting lento: 30000)
VITE_API_TIMEOUT_MS=15000

# Versión visible / PWA update prompt
VITE_APP_VERSION=1.0.0

# PWA master switch — false en producción hasta V1.1
VITE_PWA_ENABLED=false
